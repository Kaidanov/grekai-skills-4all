# soc-investigator — local automation credentials (copy to .env; .env is git-ignored)
# Only VT_API_KEY is required. The AZ_* / LA_* vars are optional and unlock the
# automated Defender + Sentinel stages in scripts/run_local.py. With none of them,
# run_local.py simply walks you through the manual steps (see QUICKSTART.md).

# --- VirusTotal (required for verdicts) ---
VT_API_KEY=

# --- Microsoft Entra app (optional: enables Defender + Sentinel automation) ---
# Needs an app registration with app permissions:
#   ThreatHunting.Read.All (Microsoft Graph)  → Defender Advanced Hunting
#   Log Analytics Reader on the workspace      → Sentinel queries
AZ_TENANT_ID=
AZ_CLIENT_ID=
AZ_CLIENT_SECRET=

# Log Analytics / Sentinel workspace GUID (for the blast-radius query)
LA_WORKSPACE_ID=

# --- Only needed if you want run_local.py --close to PATCH incidents via ARM ---
AZ_SUBSCRIPTION_ID=
AZ_RESOURCE_GROUP=
LA_WORKSPACE_NAME=
